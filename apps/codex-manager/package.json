{
  "name": "codex-manager",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "cargo build -p codex-manager-launcher --release && tauri build",
    "build:windows": "cargo build -p codex-manager-launcher --release && tauri build --bundles msi",
    "build:mac": "cargo build -p codex-manager-launcher --release && tauri build --bundles app,dmg",
    "check": "tsc --noEmit -p tsconfig.json",
    "vite:dev": "vite --host 127.0.0.1 --port 1421",
    "vite:build": "vite build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4"
  }
}
